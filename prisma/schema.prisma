// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  // URL-safe public gallery identifier (/gallery/[slug]); generated at
  // creation from the name/email (lib/slug.ts) and never changed after.
  slug         String   @unique
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  photos       Photo[]

  @@map("users")
}

// Public-facing customer accounts (gallery visitors). Kept separate from the
// admin `User` model: customer accounts never grant access to /admin, they
// only exist so a customer's email is on record (and so they can log back in)
// across sessions. passwordHash is null for OAuth-only accounts (Google/Facebook).
model CustomerAccount {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String?  @map("password_hash")
  name         String?
  provider     String   @default("credentials")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("customer_accounts")
}

model Photo {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  description  String?
  imageUrl     String   @map("image_url")
  storagePath  String   @map("storage_path")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  // Restrict (not Cascade): deleting a user must not silently destroy their
  // photos — a cascade would also bypass deletePhotoAction's storage cleanup
  // and leave orphaned MinIO objects. deleteUserAction surfaces this as a
  // friendly error instead.
  userId       String   @map("user_id") @db.Uuid
  user         User     @relation(fields: [userId], references: [id], onDelete: Restrict)

  selections   SelectionPhoto[]

  @@index([isActive, createdAt(sort: Desc)])
  @@index([userId, createdAt(sort: Desc)])
  @@map("photos")
}

model CustomerSelection {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerEmail  String   @map("customer_email")
  customerName   String?  @map("customer_name")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  photos         SelectionPhoto[]

  @@index([createdAt(sort: Desc)])
  @@map("customer_selections")
}

model SelectionPhoto {
  selectionId String            @map("selection_id") @db.Uuid
  photoId     String            @map("photo_id") @db.Uuid
  selection   CustomerSelection @relation(fields: [selectionId], references: [id], onDelete: Cascade)
  photo       Photo             @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@id([selectionId, photoId])
  @@map("selection_photos")
}

// Login attempt throttling (BFT-32). `scope` keeps admin and customer
// lockouts independent even if the same email string were ever used in
// both tables — those are otherwise fully separate identities (see
// lib/auth.ts's comment on the two non-overlapping providers).
model LoginAttempt {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  identifier  String
  scope       String
  failedCount Int       @default(0) @map("failed_count")
  lockedUntil DateTime? @map("locked_until") @db.Timestamptz
  updatedAt   DateTime  @updatedAt @map("updated_at") @db.Timestamptz

  @@unique([identifier, scope])
  @@map("login_attempts")
}
