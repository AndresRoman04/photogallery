// This is your Prisma schema file,
// learn more about it in the docs: https://pris.ly/d/prisma-schema

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
}

model User {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String   @map("password_hash")
  name         String?
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("users")
}

// Public-facing customer accounts (gallery visitors). Kept separate from the
// admin `User` model: customer accounts never grant access to /admin, they
// only exist so a customer's email is on record (and so they can log back in)
// across sessions. passwordHash is null for OAuth-only accounts (Google/Facebook).
model CustomerAccount {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  email        String   @unique
  passwordHash String?  @map("password_hash")
  name         String?
  provider     String   @default("credentials")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("customer_accounts")
}

model Photo {
  id           String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  title        String
  description  String?
  imageUrl     String   @map("image_url")
  storagePath  String   @map("storage_path")
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz

  selections   SelectionPhoto[]

  @@index([isActive, createdAt(sort: Desc)])
  @@map("photos")
}

model CustomerSelection {
  id             String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  customerEmail  String   @map("customer_email")
  customerName   String?  @map("customer_name")
  notes          String?
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  photos         SelectionPhoto[]

  @@index([createdAt(sort: Desc)])
  @@map("customer_selections")
}

model SelectionPhoto {
  selectionId String            @map("selection_id") @db.Uuid
  photoId     String            @map("photo_id") @db.Uuid
  selection   CustomerSelection @relation(fields: [selectionId], references: [id], onDelete: Cascade)
  photo       Photo             @relation(fields: [photoId], references: [id], onDelete: Cascade)

  @@id([selectionId, photoId])
  @@map("selection_photos")
}
